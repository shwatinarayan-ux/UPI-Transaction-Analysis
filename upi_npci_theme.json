        "fontFamily": [{ "value": "Segoe UI" }],
        "fontSize": [{ "value": 12 }],
        "color": [{ "value": "#1A1A2E" }]
      }
    },
    "card": {
      "*": {
        "backgroundColor": [{ "value": "#F0F4FF" }],
        "border": [{ "value": "#3B1F8C" }]
      }
    },
    "columnChart": {
